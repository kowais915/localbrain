{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog\n\nAll notable changes to localbrain are documented here. This file is generated by semantic-release from Conventional Commits."
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "pkgRoot": "packages/cli"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "npm run build && npm run build --workspace localbrain && npm version ${nextRelease.version} --no-git-tag-version --allow-same-version --workspace localbrain-client && npm pack --workspace localbrain --pack-destination .",
        "publishCmd": "echo \"//registry.npmjs.org/:_authToken=${NPM_TOKEN}\" >> $HOME/.npmrc && npm publish --workspace localbrain-client --access public"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "localbrain-*.tgz",
            "label": "localbrain tarball (install with: npm i <this-file>)"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "packages/cli/package.json", "packages/lib/package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
