# ── dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── build output (regenerated by `npm run build`) ────────────
dist/
*.tsbuildinfo

# ── packaged artifacts (created by npm pack / releases) ──────
*.tgz
*.tar.gz

# ── local model cache & runtime state (never commit models) ──
.localbrain/
*.gguf
server.json
pids/

# ── env / secrets ────────────────────────────────────────────
.env
.env.*
!.env.example

# ── partial / in-flight downloads ────────────────────────────
*.part
*.download

# ── logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── test / coverage ──────────────────────────────────────────
coverage/
.nyc_output/

# ── caches ───────────────────────────────────────────────────
.cache/
.turbo/
.eslintcache

# ── editor / OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── scratch / transfer artifacts (never commit) ──────────────
_to_delete/
