{
  "name": "localbrain-client",
  "version": "0.4.0",
  "description": "Featherweight client for a localbrain endpoint — free, private, local AI (ai.chat / classify / extract / summarize / embed). Zero dependencies.",
  "keywords": [
    "ai",
    "llm",
    "local",
    "offline",
    "privacy",
    "openai-compatible",
    "localbrain",
    "client"
  ],
  "homepage": "https://github.com/kowais915/localbrain#readme",
  "bugs": {
    "url": "https://github.com/kowais915/localbrain/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kowais915/localbrain.git",
    "directory": "packages/lib"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
