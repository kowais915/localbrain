{
  "name": "localbrain-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Give any app a free, private AI that runs on the user's own machine. Monorepo root (not published).",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kowais915/localbrain.git"
  },
  "homepage": "https://github.com/kowais915/localbrain#readme",
  "bugs": {
    "url": "https://github.com/kowais915/localbrain/issues"
  },
  "workspaces": [
    "packages/lib",
    "packages/detection",
    "packages/runtime",
    "packages/adapters",
    "packages/cli"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean && rimraf packages/*/dist",
    "typecheck": "tsc --build --dry 2>/dev/null || tsc --build",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "npm run build && node scripts/e2e.mjs",
    "dev:cli": "npm run build && node packages/cli/dist/cli.js",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "semantic-release": "^25.0.8",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
